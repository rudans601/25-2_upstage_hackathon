        144
      ],
      "id": "03ad3068-270e-408c-834c-3980d090293a",
      "name": "Solar Chat Model"
    },
    {
      "parameters": {
        "additionalFields": {},
        "requestOptions": {}
      },
      "type": "n8n-nodes-serpapi.serpApi",
      "typeVersion": 1,
      "position": [
        1280,
        -48
      ],
      "id": "6000283c-0a40-473b-84af-8137ef70029e",
      "name": "Google search"
    },
    {
      "parameters": {
        "jsCode": "// 1. AI Agent가 보낸 텍스트를 가져옵니다.\nvar text = $('AI Agent').item.json.output;\n\n// 2. 텍스트에서 마지막 JSON 블록을 찾습니다. (*? 사용)\nvar matches = text.match(/(\\{[\\s\\S]*?\\})/g);\nvar keywords = []; // 기본값\n\nif (matches) {\n  var lastJsonString = matches[matches.length - 1];\n  \n  try {\n    var parsedJson = JSON.parse(lastJsonString);\n    \n    // 3. 키워드 배열을 추출합니다. (두 가지 구조 모두 확인)\n    if (parsedJson.json && parsedJson.json.keywords) {\n      keywords = parsedJson.json.keywords;\n    } else if (parsedJson.keywords) {\n      keywords = parsedJson.keywords;\n    }\n    \n  } catch (e) {\n    // 파싱 실패해도 오류 내지 않음\n  }\n}\n\n// 4. 추출된 키워드를 다음 노드로 보냅니다.\nreturn {\n  json: {\n    search_query: keywords.join(' ')\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        -48
      ],
      "id": "215265f1-14a6-4492-b4f3-7f5dfd28b98c",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.generatedPrompt }}",
        "options": {
          "systemMessage": "너는 꼼꼼한 팩트체커 AI야.\n가짜뉴스인지 아닌지 판단해줘\n판단 기준은 비슷한 기사의 갯수가 얼마나 되는지(5개 이상), 또는 메이저 뉴스 기업들 등의 기준으로 해줘. "
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        1600,
        224
      ],
      "id": "6bec872a-a7c2-4e6e-916a-cdac5abd7011",
      "name": "AI Agent1"
    },
    {
      "parameters": {
        "jsCode": "// 1. (수정됨) $input.first()를 사용해 'organic_results' 데이터를 가져옵니다.\nconst searchResults = $input.first().json.organic_results\n  // 2. 상위 5개만 자릅니다.\n  .slice(0, 5)\n  // 3. 각 항목을 'title', 'snippet', 'source'만 남도록 가공합니다.\n  .map(r => ({\n    title: r.title,\n    snippet: r.snippet,\n    source: r.source\n  }));\n\n// 4. (수정됨) 'HTML1' 노드의 '첫 번째' 아이템에서 [원본 기사] 텍스트를 가져옵니다.\n// ❗ 'HTML1'은 실제 텍스트가 있는 노드의 이름이어야 합니다.\nconst originalText = $('HTML1').first().json.text;\n\n// 5. 프롬프트를 정의하고, 변수를 삽입하고, backtick으로 닫습니다.\nconst prompt = `너는 요약 봇이야.\n아래 [원본 기사]와 [검색 결과]를 비교해서,\n[원본 기사]가 기자체널 검색 결과에 분석하고,\n\n가짜뉴스인지 아닌지 판단해줘\n판단 기준은 비슷한 기사의 갯수가 얼마나 되는지(5개 이상), 또는 메이저 뉴스 기업들 등의 기준으로 해줘. \n다른 설명을 모두 생략하고 아래 [JSON 형식]에 맞춰서 한 줄로 가짜뉴스인지 아닌지 분석해줘.\n\n[원본 기사]\n${originalText}\n\n[검색 결과]\n${JSON.stringify(searchResults, null, 2)}\n`; // <-- ❗ 닫는 백틱(`)\n\n// 6. 다음 노드로 보낼 데이터를 반환(return)합니다.\nreturn [\n  {\n    json: {\n      generatedPrompt: prompt\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
